	  Position		  [10, 692, 35, 718]
	  ZOrder		  30
	  Port			  "11"
	  IconDisplay		  "Port number"
	}
	Block {
	  BlockType		  SubSystem
	  Name			  "ADAMS Plant"
	  SID			  "4459"
	  Ports			  [1, 1]
	  Position		  [260, 380, 360, 430]
	  ZOrder		  1
	  BackgroundColor	  "red"
	  LoadFcn		  "%check based on dialog box setting for when setting by popup menu                                      "
	  "       \nif exist('ADAMS_solver_type')                                                                             "
	  "    \n  if strcmp(ADAMS_solver_type,'C++')                                                                         "
	  " \n    set_param(gcb,'exetyp','C++');                                                                            \n"
	  "  else                                                                                                        \n   "
	  " set_param(gcb,'exetyp','Fortran');                                                                        \n  end "
	  "                                                                                                        \nelse     "
	  "                                                                                                     \n  set_param("
	  "gcb,'exetyp','C++');                                                                              \nend            "
	  "                                                                                               \n%set the mode if u"
	  "sing acar_solver                                                                            \n%REQUIRED HERE BECAUS"
	  "E BELOW CAUSES MDLTERMINATE TO BE CALLED 2 TIMES IN MIDDLE OF SIMULATION WHEN SET IN MASK\n                        "
	  "                                                                                      \n%enable the direct feedthro"
	  "ugh, sim mode, anim mode parameters by default                                     \n                              "
	  "                                                                                \nif exist('set_some_params_states'"
	  ")                                                                            \n                                    "
	  "                                                                          \n  set_some_params_states({'dft','modsim"
	  "','modani'},{'on','on','on'},'MaskEnables',gcb)                        \n  %turn on direct feedthrough option      "
	  "                                                                    \n  set_some_params_states({'dft'},{'on'},'Mask"
	  "Visibilities',gcb)                                               \n                                                "
	  "                                                              \n end                                               "
	  "                                                           \n                                                      "
	  "                                                        \n                                                         "
	  "                                                     \nif exist('ADAMS_exec')                                      "
	  "                                                  \n  if and(strcmp(get_param(gcb,'exesol'),'ADAMS_exec'),strcmp(AD"
	  "AMS_exec,'acar_solver'))                       \n    %set the sim mode to discrete -- only supported mode          "
	  "                                            \n    set_param(gcb,'modsim','discrete')                               "
	  "                                         \n     %turn off direct feedthrough option                                "
	  "                                      \n     set_some_params_states({'dft'},{'off'},'MaskVisibilities',gcb)        "
	  "                                   \n    %set the animation mode to batch -- only supported mode                   "
	  "                                \n    set_param(gcb,'modani','batch')                                              "
	  "                             \n    %disable the direct feedthrough, sim mode, anim mode parameters                 "
	  "                          \n    set_some_params_states({'modsim','modani'},{'off','off'},'MaskEnables',gcb)        "
	  "                       \n  end                                                                                     "
	  "                    \nend                                                                                          "
	  "                 "
	  InitFcn		  "clear mex"
	  OpenFcn		  "open_system(gcb,'mask')                                                                                "
	  "                                          \nif not(exist('set_some_params_states'))                                "
	  "                                                                          \n                                       "
	  "                                                                                                          \nwarning"
	  "('The script \"set_some_params_states.m\" cannot be found in the MATLAB PATH.  Cannot update the ADAMS Plant S-Func"
	  "tion parameters.')       \n                                                                                        "
	  "                                                         \nwarning('Recommended action(optional):  run the Adams/Co"
	  "ntrols .m file first to help choose the correct settings in the Adams S-Function block.')\n                        "
	  "                                                                                                                   "
	  "      \nend                                                                                                        "
	  "                                      "
	  RequestExecContextInheritance	off
	  Object {
	    $PropName		    "MaskObject"
	    $ObjectID		    21
	    $ClassName		    "Simulink.Mask"
	    Type		    "Adams Plant"
	    Description		    "Simulate any Adams plant model either in Adams/Solver form (.adm file) or in Adams/View form (."
	    "cmd file)"
	    Help		    "<html>\nThis S-Function represents the non-linear Adams Plant with the inputs sent to the Adams model "
	    "<br>\n and the outputs generated by the Adams model.  See the Adams/Controls documentation for more <br>\ninforma"
	    "tion.  This plant uses the following variables:<br>\n<br>\n<b>ADAMS_sysdir  :</b> Adams installation directory<br"
	    ">\n<b>ADAMS_inputs  :</b> Input variables View names vector<br>\n<b>ADAMS_outputs :</b> Outputs variables View na"
	    "mes vector<br>\n<b>ADAMS_prefix  : </b>ADAMS model files prefix (.adm, .cmd); also doubles as output files prefix"
	    "<br>\n<b>ADAMS_exec :</b> Adams/Solver user library or keyword (e.g., acar_solver)<br> \n<b>ADAMS_static :</b> ye"
	    "s|no - initial static before Co-simulation(discrete)/Function Evaluation(continuous)<br>\n<b>ADAMS_init :</b>Init"
	    "ialization commands (i.e., Adams/View or Solver commands, depending on setting for Animation mode)<br>\n<b>ADAMS_"
	    "cwd : </b> Current working directory (for TCP/IP)<br>\n<b>ADAMS_host : </b>Name of Adams server host (for TCP/IP)"
	    "<br>\n<b>ADAMS_mode :</b> Linear or non-linear (i.e., co-sim, function eval)<br>\n<b>ADAMS_solver_type :</b>Fortr"
	    "an or C++ (used to set popup menu when first loaded) <br>\n\n\n<br>\nThe following settings can be chosen:<br>\n<"
	    "br>\n<b>Adams/Solver type:</b>  Fortran or C++ (will also set ADAMS_solver_type)<br>\n<b>Interprocess option:</b>"
	    " Pipe(DDE) or TCP/IP; TCP/IP can allow different machines run Adams and MATLAB<br>\n<b>Animation mode:</b> batch "
	    "(Solver, uses .adm) or interactive (View, uses .cmd)<br>\n<b>Simulation mode:</b> discrete (Co-simulation) or con"
	    "tinuous (Function Evaluation)<br>\n<b>Discrete Computational Order - Simulink Lead Adams:</b> for discrete mode, "
	    "chooses if Simulink leads the integration (yes) or lags (no);<br> if set to \"no\", can remove algebraic loop<br>"
	    "\n<b>Plant input interpolation order:</b> 0 = zero-order hold; 1 = linear (discrete mode only, where Simulink lea"
	    "ds)<br>\n<b>Plant output extrapolation order:</b> 0 = zero-order hold;1 = linear(discrete mode only, where Simuli"
	    "nk leads)<br>\n<b>Plant input extrapolation order:</b> 0 = zero-order hold; 1 = linear (discrete mode only, where"
	    " Adams leads)<br>\n<b>Plant output interpolation order:</b> 0 = zero-order hold;1 = linear(discrete mode only, wh"
	    "ere Adams leads)<br>\n<b>Direct feedthrough:</b> yes|no - yes = Input directly effect output(continuous mode-only"
	    ")<br> \n<b>Communication interval:</b> Time step at which Co-simulation exchange information (e.g.,0.005); also c"
	    "ontrols <br>output for continuous mode (Function Evaluation)<br>\n<b>Number of communications per output step: </"
	    "b>Sets Adams output rate (.res, .req, .gra) integer value (default: 1)<br>\n</html>"
	    Display		    "disp( 'MSC Software' )"
	    Array {
	      Type		      "Simulink.MaskParameter"
	      Dimension		      23
	      Object {
		$ObjectID		22
		Type			"edit"
		Name			"exevie"
		Prompt			"Adams install directory"
		Value			"ADAMS_sysdir"
		Visible			"off"
	      }
	      Object {
		$ObjectID		23
		Type			"edit"
		Name			"nam_in"
		Prompt			"Adams/View input names"
		Value			"ADAMS_inputs"
		Visible			"off"
	      }
	      Object {
		$ObjectID		24
		Type			"edit"
		Name			"namout"
		Prompt			"Adams/View output names"
		Value			"ADAMS_outputs"
		Visible			"off"
	      }
	      Object {
		$ObjectID		25
		Type			"edit"
		Name			"nampre"
		Prompt			"Adams model file prefix"
		Value			"ADAMS_prefix"
	      }
	      Object {
		$ObjectID		26
		Type			"edit"
		Name			"outfil"
		Prompt			"Output files prefix (opt.: if blank - no output)"
		Value			"ADAMS_prefix"
	      }
	      Object {
		$ObjectID		27
		Type			"edit"
		Name			"exesol"
		Prompt			"User executable (opt.: if blank - use standard)"
		Value			"ADAMS_exec"
		Visible			"off"
		Callback		"if exist('set_some_params_states')\n%enable the direct feedthrough, sim mode, anim mode parameters\nset_s"
		"ome_params_states({'dft','modsim','modani'},{'on','on','on'},'MaskEnables',gcb)\n%turn on direct feedthrough option\n"
		"set_some_params_states({'dft'},{'on'},'MaskVisibilities',gcb) \nend\n\nif exist('ADAMS_exec')   \n  if and(strcmp(ge"
		"t_param(gcb,'exesol'),'ADAMS_exec'),strcmp(ADAMS_exec,'acar_solver'))\n    %set the sim mode to discrete -- only sup"
		"ported mode\n    %REMOVED:  BELOW CAUSES MDLTERMINATE TO BE CALLED 2 TIMES IN MIDDLE OF SIMULATION\n    %Now in Load"
		"Fcn callback\n    %set_param(gcb,'modsim','discrete')\n     %turn off direct feedthrough option\n    set_some_params"
		"_states({'dft'},{'off'},'MaskVisibilities',gcb)\n    %set the animation mode to batch -- only supported mode\n    %R"
		"EMOVED:  BELOW CAUSES MDLTERMINATE TO BE CALLED 2 TIMES IN MIDDLE OF SIMULATION\n    %Now in LoadFcn callback\n    %"
		"set_param(gcb,'modani','batch')\n    %disable the direct feedthrough, sim mode, anim mode parameters\n    set_some_p"
		"arams_states({'modsim','modani'},{'off','off'},'MaskEnables',gcb)\n  end\nend\n\n\n\n"
	      }
	      Object {
		$ObjectID		28
		Type			"edit"
		Name			"stat"
		Prompt			"Initial static simulation flag "
		Value			"ADAMS_static"
		Visible			"off"
	      }
	      Object {
		$ObjectID		29
		Type			"edit"
		Name			"inicmd"
		Prompt			"Initialization commands"
		Value			"[ADAMS_init]"
		Visible			"off"
	      }
	      Object {
		$ObjectID		30
		Type			"popup"
		Array {
		  Type			  "Cell"
		  Dimension		  2
		  Cell			  "Fortran"
		  Cell			  "C++"
		  PropName		  "TypeOptions"
		}
		Name			"exetyp"
		Prompt			"Adams/Solver type"
		Value			"C++"
		Evaluate		"off"
		Callback		"if strcmp(get_param(gcb,'exetyp'),'C++')\n    ADAMS_solver_type='C++';\nelse\n    ADAMS_solver_type='Fort"
		"ran';\nend"
	      }
	      Object {
		$ObjectID		31
		Type			"popup"
		Array {
		  Type			  "Cell"
		  Dimension		  2
		  Cell			  "PIPE(DDE)"
		  Cell			  "TCP/IP"
		  PropName		  "TypeOptions"
		}
		Name			"comtyp"
		Prompt			"Interprocess option"
		Value			"PIPE(DDE)"
		Evaluate		"off"
		Callback		"if exist('set_some_params_states')\nif strcmp(get_param(gcb,'comtyp'),'PIPE(DDE)')\n    %turn off cwd, ho"
		"st options\n    set_some_params_states({'ada_host','workdir'},{'off','off'},'MaskVisibilities',gcb)\nelse%if strcmp("
		"get_param(gcb,'modsim'),'TCP/IP')\n    %turn on cwd, host options\n    set_some_params_states({'ada_host','workdir'}"
		",{'on','on'},'MaskVisibilities',gcb)\nend\nend"
	      }
	      Object {
		$ObjectID		32
		Type			"edit"
		Name			"workdir"
		Prompt			"Adams working directory"
		Value			"ADAMS_cwd"
		Visible			"off"
	      }
	      Object {
		$ObjectID		33
		Type			"edit"
		Name			"ada_host"
		Prompt			"Adams host"
		Value			"ADAMS_host"
		Visible			"off"
	      }
	      Object {
		$ObjectID		34
		Type			"popup"
		Array {
		  Type			  "Cell"
		  Dimension		  2
		  Cell			  "batch"
		  Cell			  "interactive"
		  PropName		  "TypeOptions"
		}
		Name			"modani"
		Prompt			"Animation mode"
		Value			"batch"
		Evaluate		"off"
	      }
	      Object {
		$ObjectID		35
		Type			"popup"
		Array {
		  Type			  "Cell"
		  Dimension		  2
		  Cell			  "discrete"
		  Cell			  "continuous"
		  PropName		  "TypeOptions"
		}
		Name			"modsim"
		Prompt			"Simulation mode"
		Value			"discrete"
		Evaluate		"off"
		Callback		"if exist('set_some_params_states')\nif strcmp(get_param(gcb,'modsim'),'discrete')\n     %turn off direct "
		"feedthrough option\n    set_some_params_states({'dft'},{'off'},'MaskVisibilities',gcb)\n    %turn on discrete co-sim"
		" type if want to see more\n    if strcmp(get_param(gcb,'more'),'on')\n        set_some_params_states({'simulink_lead"
		"_cosim'},{'on'},'MaskVisibilities',gcb)\n    end\n    if strcmp(get_param(gcb,'simulink_lead_cosim'),'yes')\n       "
		" %turn on interpolation/extrapolation options\n        set_some_params_states({'pin_interp_order','pout_extrap_order"
		"',},{'on','on'},'MaskVisibilities',gcb)\n    else\n        set_some_params_states({'pin_extrap_order','pout_interp_o"
		"rder'},{'on','on'},'MaskVisibilities',gcb)\n    end     \nelse%if strcmp(get_param(gcb,'modsim'),'continuous')\n    "
		" %turn off direct feedthrough option\n    set_some_params_states({'dft'},{'on'},'MaskVisibilities',gcb)\n    %turn o"
		"ff interpolation/extrapolation options\n    set_some_params_states({'pin_interp_order','pout_extrap_order','pin_extr"
		"ap_order','pout_interp_order','simulink_lead_cosim'},{'off','off','off','off','off'},'MaskVisibilities',gcb)\nend\ne"
		"nd"
	      }
	      Object {
		$ObjectID		36
		Type			"popup"
		Array {
		  Type			  "Cell"
		  Dimension		  2
		  Cell			  "no"
		  Cell			  "yes"
		  PropName		  "TypeOptions"
		}
		Name			"dft"
		Prompt			"Direct feedthrough "
		Value			"no"
		Evaluate		"off"
		Visible			"off"
	      }
	      Object {
		$ObjectID		37
		Type			"popup"
		Array {
		  Type			  "Cell"
		  Dimension		  2
		  Cell			  "yes"
		  Cell			  "no"
		  PropName		  "TypeOptions"
		}
		Name			"simulink_lead_cosim"
		Prompt			"Discrete Computational Order - Simulink Leads Adams"
		Value			"yes"
		Evaluate		"off"
		Visible			"off"
		Callback		"if exist('set_some_params_states')\nif (strcmp(get_param(gcb,'simulink_lead_cosim'),'yes') && strcmp(get_"
		"param(gcb,'modsim'),'discrete'))\n     %turn off unused interpolate/extrapolate options\n    set_some_params_states("
		"{'pin_extrap_order','pout_interp_order'},{'off','off'},'MaskVisibilities',gcb)\n    %turn on used interpolate/extrap"
		"olate options\n    set_some_params_states({'pin_interp_order','pout_extrap_order'},{'on','on'},'MaskVisibilities',gc"
		"b)   \nelseif (strcmp(get_param(gcb,'simulink_lead_cosim'),'no') && strcmp(get_param(gcb,'modsim'),'discrete'))\n   "
		" %turn on used interpolate/extrapolate options\n    set_some_params_states({'pin_extrap_order','pout_interp_order'},"
		"{'on','on'},'MaskVisibilities',gcb)\n     %turn off unused interpolate/extrapolate options\n    set_some_params_stat"
		"es({'pin_interp_order','pout_extrap_order'},{'off','off'},'MaskVisibilities',gcb) \nend\nend"
	      }
	      Object {
		$ObjectID		38
		Type			"popup"
		Array {
		  Type			  "Cell"
		  Dimension		  2
		  Cell			  "0"
		  Cell			  "1"
		  PropName		  "TypeOptions"
		}
		Name			"pin_interp_order"
		Prompt			"Plant input interpolation order"
		Value			"0"
		Evaluate		"off"
	      }
	      Object {
		$ObjectID		39
		Type			"popup"
		Array {
		  Type			  "Cell"
		  Dimension		  2
		  Cell			  "0"
		  Cell			  "1"
		  PropName		  "TypeOptions"
		}
		Name			"pout_extrap_order"
		Prompt			"Plant output extrapolation order"
		Value			"0"
		Evaluate		"off"
	      }
	      Object {
		$ObjectID		40
		Type			"popup"
		Array {
		  Type			  "Cell"
		  Dimension		  2
		  Cell			  "0"
		  Cell			  "1"
		  PropName		  "TypeOptions"
		}
		Name			"pin_extrap_order"
		Prompt			"Plant input extrapolation order"
		Value			"0"
		Evaluate		"off"
		Visible			"off"
	      }
	      Object {
		$ObjectID		41
		Type			"popup"
		Array {
		  Type			  "Cell"
		  Dimension		  2
		  Cell			  "0"
		  Cell			  "1"
		  PropName		  "TypeOptions"
		}
		Name			"pout_interp_order"
		Prompt			"Plant output interpolation order"
		Value			"0"
		Evaluate		"off"
		Visible			"off"
	      }
	      Object {
		$ObjectID		42
		Type			"edit"
