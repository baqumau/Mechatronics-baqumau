		Callback		"if exist('set_some_params_states')\nif (strcmp(get_param(gcb,'more'),'on'))\n     %turn on infrequently u"
		"sed options\n    set_some_params_states({'exevie','nam_in','namout','exesol','stat','inicmd'},{'on','on','on','on','"
		"on','on'},'MaskVisibilities',gcb) \n    if strcmp(get_param(gcb,'modsim'),'discrete')\n        set_some_params_state"
		"s({'simulink_lead_cosim'},{'on'},'MaskVisibilities',gcb)\n    end\nelseif (strcmp(get_param(gcb,'more'),'off'))\n   "
		" %turn off infrequently used options\n    set_some_params_states({'exevie','nam_in','namout','exesol','stat','inicmd"
		"'},{'off','off','off','off','off','off'},'MaskVisibilities',gcb)\n    if strcmp(get_param(gcb,'modsim'),'discrete')\n"
		"        set_some_params_states({'simulink_lead_cosim'},{'off'},'MaskVisibilities',gcb)\n    end\nend\nend\n"
	      }
	      PropName		      "Parameters"
	    }
